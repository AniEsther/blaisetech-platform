# Copy this file and rename the copy to ".env" then fill in real values

# Server
PORT=5000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blaisetech_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT (login tokens)
JWT_SECRET=replace_this_with_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Paystack (online payments for the Shop). Get these from your Paystack
# dashboard: https://dashboard.paystack.com/#/settings/developer
# Use the "test" keys while developing, then switch to "live" keys when you launch.
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Email notifications (sent to the admin whenever a customer books a
# service, places an order, uploads a payment receipt, applies for a job,
# etc). Leave blank to skip sending emails — the app will just log the
# notification to the console instead, so nothing breaks without this set up.
# Example values for a Gmail account (use an "app password", not your real password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your_16_character_app_password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_NOTIFICATION_EMAIL=admin@blaisetech.com
FRONTEND_URL=http://localhost:5173